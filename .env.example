# StatsBomb Open Data does not require credentials.
# Use this only if you want to store generated data outside ./data.
NARRADOR_DATA_DIR=data

# Optional: used by Narrador AI. If absent, the app uses local fallback narrative templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: used by report history/audit records.
NARRADOR_USER_EMAIL=demo@example.com

# Basic v01 authentication.
# Change these before running a shared deployment.
APP_SECRET_KEY=change-me-with-a-long-random-secret
APP_BASE_URL=http://localhost:8501
SEED_ADMIN_EMAIL_1=admin1@example.com
SEED_ADMIN_EMAIL_2=admin2@example.com
SEED_ADMIN_PASSWORD=ChangeMe-v01!
INVITATION_TTL_HOURS=72

# Optional SMTP placeholders for email delivery.
# If absent, invitations are shown on screen for local/development use.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Narrador Futbol
SMTP_USE_TLS=true
SMTP_USE_SSL=false
