# StatsBomb Open Data does not require credentials.
# Use this only if you want to store generated data outside ./data.
NARRADOR_DATA_DIR=data

# Optional: used by Narrador AI. If absent, the app uses local fallback narrative templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: used by report history/audit records.
NARRADOR_USER_EMAIL=demo@example.com
